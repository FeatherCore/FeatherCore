#!/bin/sh
# /init - Initial process for FeatherCore

# Mount essential filesystems
echo "Mounting filesystems..."
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

# Set hostname
echo "FeatherCore" > /proc/sys/kernel/hostname

# Load kernel modules (if any)
# modprobe -a

# Initialize network (if configured)
# /etc/init.d/network start

# Start system logger
# /usr/sbin/syslogd

# Execute rc scripts
if [ -x /etc/rc.local ]; then
    /etc/rc.local &
fi

# Start shell or init program
echo "FeatherCore initialized successfully!"
echo "Starting shell..."
exec /bin/sh
